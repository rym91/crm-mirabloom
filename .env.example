# ---- Postgres (локальный dev через docker-compose) ----
DATABASE_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"

# ---- Auth.js v5 ----
# openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
AUTH_TRUST_HOST=true

# ---- Пароли для сида 3 пользователей (сменить после первого входа) ----
SEED_PW_ADMIN="change-me-admin"
SEED_PW_MANAGER1="change-me-1"
SEED_PW_MANAGER2="change-me-2"

# ---- Почта Hostinger (Layer 2) ----
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="hello@mirabloom.eu"
SMTP_PASS=""
MAIL_FROM="Tetiana Rymarova <hello@mirabloom.eu>"

# ТЕСТ-РЕЖИМ: по умолчанию ВКЛЮЧЁН (любое значение кроме "false").
# Все письма уходят только на EMAIL_TEST_RECIPIENT с темой [TEST → реальный-адрес].
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT="rymarev91@gmail.com"

# ---- AI (Layer 2): Claude через подписку Max (Agent SDK) ----
# Локально пусто — подхватывается логин Claude Code; на сервере: `claude setup-token`
LLM_MODEL="sonnet"
CLAUDE_CODE_OAUTH_TOKEN=""

# ---- CRM <-> n8n вебхук входящих (Layer 2): openssl rand -base64 24 ----
CRM_INBOUND_SECRET=""

# ---- Защита крона follow-up'ов: openssl rand -base64 24 ----
CRON_SECRET=""

# ---- Мастер-ключ шифрования API-секретов (Фаза 2): openssl rand -base64 32 ----
SECRET_KEY_V1=""
SECRET_KEY_CURRENT="1"