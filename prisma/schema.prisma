// Amazon Accounts & Sites CRM — supplier-outreach MVP
// Prisma 6.x + PostgreSQL. См. docs/04-data-model.md и docs/10-fba-spain-integration.md.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"] // native = Windows-dev; debian = Docker runner
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------
enum Role {
  ADMIN
  MEMBER
}

enum SupplierStatus {
  CANDIDATE
  QUALIFIED
  CONTACTED
  REPLIED
  QUOTED
  NEGOTIATING
  ACTIVE
  REJECTED
  ON_HOLD
  MANUAL_REVIEW
}

enum LeadSource {
  BRAND_PAGE
  DIRECTORY
  IMPRESSUM
  SEARCH
  REFERRAL
  TRADE_SHOW
  MANUAL
}

enum Confidence {
  HIGH
  MED
  LOW
}

enum ViesStatus {
  UNCHECKED
  VALID
  INVALID
}

enum AuthorizedHint {
  YES
  MAYBE
  NO
}

enum SupplierTier {
  CORE
  SOLID
  CONDITIONAL
  MARGINAL
  REJECT
}

enum TaskKind {
  GENERIC
  PRICE_REVIEW
  MANUAL_REVIEW
  FILL_FORM
}

enum TemplateKind {
  INTRO
  FOLLOWUP_1
  FOLLOWUP_2
  QUALIFICATION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENT
  RECEIVED
  FAILED
}

enum EntityType {
  SUPPLIER
  CONTACT
  EMAIL_THREAD
}

enum ReminderChannel {
  NONE
  IN_APP
  EMAIL
  TELEGRAM
}

// ---------- USER ----------
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedSuppliers Supplier[]      @relation("SupplierOwner")
  assignedTasks  Task[]
  notes          Note[]
  sentMessages   EmailMessage[]
  documents      Document[]
  templates      EmailTemplate[]
}

// ---------- SUPPLIER ----------
model Supplier {
  id             String         @id @default(cuid())
  name           String
  country        String?
  website        String?
  status         SupplierStatus @default(CANDIDATE)
  category       String?
  leadSource     LeadSource?
  sourceUrl      String?
  contactFormUrl String?
  vatNumber      String?
  viesStatus     ViesStatus     @default(UNCHECKED)
  score          Int? // 0-100 скоринг (модель FBA Spain)
  tier           SupplierTier?
  optedOut       Boolean        @default(false) // отписался / не контактировать (GDPR/compliance)
  notes          String?
  ownerId        String?
  owner          User?          @relation("SupplierOwner", fields: [ownerId], references: [id])
  customFields   Json?          @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contacts Contact[]
  threads  EmailThread[]
  messages EmailMessage[]
  tags     SupplierTag[]
  brands   SupplierBrand[]

  @@index([status])
  @@index([ownerId])
  @@index([name])
}

// ---------- CONTACT ----------
model Contact {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  position     String?
  isPrimary    Boolean  @default(false)
  customFields Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages EmailMessage[]

  @@index([supplierId])
  @@index([email])
}

// ---------- BRAND ----------
model Brand {
  id               String   @id @default(cuid())
  name             String   @unique
  category         String?
  nAsinsPassed     Int?
  totalDrops30     Int?
  medianBuybox     Float?
  medianMaxCost    Float?
  opportunityScore Int?
  customFields     Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  suppliers SupplierBrand[]

  @@index([opportunityScore])
}

// ---------- SUPPLIER x BRAND ----------
model SupplierBrand {
  supplierId     String
  brandId        String
  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand          Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  leadSource     LeadSource?
  sourceUrl      String?
  confidence     Confidence?
  authorizedHint AuthorizedHint?
  notes          String?
  createdAt      DateTime        @default(now())

  @@id([supplierId, brandId])
  @@index([brandId])
}

// ---------- EMAIL THREAD ----------
model EmailThread {
  id            String          @id @default(cuid())
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  subject       String
  routingToken  String          @unique @default(cuid())
  lastMessageAt DateTime?
  lastDirection EmailDirection?
  isClosed      Boolean         @default(false)
  followUpDueAt DateTime?
  followUpStep  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  messages EmailMessage[]

  @@index([supplierId])
  @@index([lastMessageAt])
  @@index([followUpDueAt])
}

// ---------- EMAIL MESSAGE ----------
model EmailMessage {
  id          String         @id @default(cuid())
  threadId    String
  thread      EmailThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?       @relation(fields: [contactId], references: [id])
  senderId    String?
  sender      User?          @relation(fields: [senderId], references: [id])
  direction   EmailDirection
  status      EmailStatus    @default(DRAFT)
  fromAddress String
  toAddress   String
  subject     String
  bodyText    String?
  bodyHtml    String?
  messageId   String?        @unique
  inReplyTo   String?
  references  String?
  aiClass     String?
  aiConfidence Float?
  aiSummary   String?  @db.Text
  sentAt      DateTime?
  receivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  attachments Document[]

  @@index([threadId])
  @@index([supplierId])
  @@index([direction])
  @@index([inReplyTo])
}

// ---------- TASK / REMINDER ----------
model Task {
  id              String          @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus      @default(TODO)
  kind            TaskKind        @default(GENERIC)
  dueAt           DateTime?
  reminderAt      DateTime?
  reminderChannel ReminderChannel @default(IN_APP)
  reminderSent    Boolean         @default(false)
  assigneeId      String?
  assignee        User?           @relation(fields: [assigneeId], references: [id])
  entityType      EntityType?
  entityId        String?
  customFields    Json?           @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([dueAt])
  @@index([reminderAt, reminderSent])
  @@index([entityType, entityId])
}

// ---------- NOTE / ACTIVITY ----------
model Note {
  id         String     @id @default(cuid())
  body       String
  authorId   String?
  author     User?      @relation(fields: [authorId], references: [id])
  entityType EntityType
  entityId   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------- TAG ----------
model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String?
  createdAt DateTime      @default(now())

  suppliers SupplierTag[]
}

model SupplierTag {
  supplierId String
  tagId      String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([supplierId, tagId])
  @@index([tagId])
}

// ---------- DOCUMENT ----------
model Document {
  id           String        @id @default(cuid())
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  uploadedById String?
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id])
  entityType   EntityType?
  entityId     String?
  messageId    String?
  message      EmailMessage? @relation(fields: [messageId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([entityType, entityId])
}

// ---------- EMAIL TEMPLATE ----------
model EmailTemplate {
  id           String       @id @default(cuid())
  name         String
  kind         TemplateKind @unique @default(INTRO)
  subject      String
  bodyHtml     String
  followUpDays Int?
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- API SECRET (Фаза 2) ----------
model ApiSecret {
  id         String       @id @default(cuid())
  name       String
  provider   String?
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes
  keyVersion Int          @default(1)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reads      SecretRead[]
}

model SecretRead {
  id        String    @id @default(cuid())
  secretId  String
  secret    ApiSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  userId    String
  action    String
  ip        String?
  createdAt DateTime  @default(now())

  @@index([secretId, createdAt])
}