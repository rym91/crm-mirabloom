# Production env for Contabo. Copy to `.env.production` on the server and fill the blanks.
# .env.production is gitignored — NEVER commit it. Generate secrets with: openssl rand -base64 32

# ---- Postgres (the crm-db service in docker-compose.prod.yml) ----
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_strong
POSTGRES_DB=crm
# App connects to the db over the internal docker network (host = service name "crm-db")
DATABASE_URL=postgresql://crm:CHANGE_ME_strong@crm-db:5432/crm?schema=public

# ---- Next.js / Auth.js ----
NODE_ENV=production
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# ---- Seed passwords (first deploy only; change after first login) ----
SEED_PW_ADMIN=CHANGE_ME
SEED_PW_MANAGER1=CHANGE_ME
SEED_PW_MANAGER2=CHANGE_ME

# ---- Email (Hostinger) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@mirabloom.eu
SMTP_PASS=CHANGE_ME_mailbox_password
MAIL_FROM=Tetiana Rymarova <hello@mirabloom.eu>

# ⚠️ KEEP TRUE until go-live. true = every outbound goes only to EMAIL_TEST_RECIPIENT.
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT=rymarev91@gmail.com

# ---- AI provider for inbound classification + intro hooks ----
# AI_PROVIDER picks the backend:
#   openai     → OpenAI Chat Completions (needs OPENAI_API_KEY). ROBUST in a container. ← in use.
#   anthropic  → official Anthropic API (needs ANTHROPIC_API_KEY). Also robust in a container.
#   agent-sdk  → Claude Max subscription via the Agent SDK (spawns the `claude` CLI).
#                Works locally (Claude Code login) but HANGS in the headless slim container — do NOT use on the server.
#   off        → no AI. Inbound replies are stored and routed to MANUAL_REVIEW for a human. Zero cost, never hangs.
AI_PROVIDER=openai
#
# For AI_PROVIDER=openai (https://platform.openai.com/account/api-keys; classification ≈ fractions of a cent/email):
OPENAI_API_KEY=CHANGE_ME_sk-proj-...
OPENAI_MODEL=gpt-4o-mini
#
# For AI_PROVIDER=anthropic instead (https://console.anthropic.com → API keys):
ANTHROPIC_API_KEY=
# LLM_MODEL=haiku        # alias haiku|sonnet|opus  (or set LLM_MODEL_ID to a full model id)
#
# For AI_PROVIDER=agent-sdk only (token from `claude setup-token`):
CLAUDE_CODE_OAUTH_TOKEN=

# ---- Machine endpoint secrets (openssl rand -base64 24) ----
CRM_INBOUND_SECRET=CHANGE_ME   # n8n -> POST /api/inbound-email (header X-CRM-Secret)
CRON_SECRET=CHANGE_ME          # protects GET /api/cron/followups (header x-cron-secret or ?secret=)
