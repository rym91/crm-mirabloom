# Production env for Contabo. Copy to `.env.production` on the server and fill the blanks.
# .env.production is gitignored — NEVER commit it. Generate secrets with: openssl rand -base64 32

# ---- Postgres (the crm-db service in docker-compose.prod.yml) ----
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_strong
POSTGRES_DB=crm
# App connects to the db over the internal docker network (host = service name "crm-db")
DATABASE_URL=postgresql://crm:CHANGE_ME_strong@crm-db:5432/crm?schema=public

# ---- Next.js / Auth.js ----
NODE_ENV=production
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# ---- Seed passwords (first deploy only; change after first login) ----
SEED_PW_ADMIN=CHANGE_ME
SEED_PW_MANAGER1=CHANGE_ME
SEED_PW_MANAGER2=CHANGE_ME

# ---- Email (Hostinger) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@mirabloom.eu
SMTP_PASS=CHANGE_ME_mailbox_password
MAIL_FROM=Tetiana Rymarova <hello@mirabloom.eu>

# ⚠️ KEEP TRUE until go-live. true = every outbound goes only to EMAIL_TEST_RECIPIENT.
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT=rymarev91@gmail.com

# ---- AI: Claude via Max subscription (Agent SDK). On the server set the OAuth token
#      from `claude setup-token` (no interactive login on a VPS). ----
LLM_MODEL=sonnet
CLAUDE_CODE_OAUTH_TOKEN=CHANGE_ME_from_claude_setup_token

# ---- Machine endpoint secrets (openssl rand -base64 24) ----
CRM_INBOUND_SECRET=CHANGE_ME   # n8n -> POST /api/inbound-email (header X-CRM-Secret)
CRON_SECRET=CHANGE_ME          # protects GET /api/cron/followups (header x-cron-secret or ?secret=)
